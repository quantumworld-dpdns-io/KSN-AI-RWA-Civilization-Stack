# Server-side URL for the Oracle simulator API.
# Local development:
ORACLE_API_URL=http://127.0.0.1:8787

# Docker Compose alternative:
# ORACLE_API_URL=http://oracle-sim:8787

# ORACLE_URL is supported as a legacy fallback. Prefer ORACLE_API_URL.

# Sepolia RPC URL for live on-chain reads in the Sepolia contracts view (viem).
# Falls back to a public endpoint if unset. Use your own Alchemy/Infura URL for reliability.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/replace-me
